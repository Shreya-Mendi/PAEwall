# CourtListener API token (free): https://www.courtlistener.com/sign-in/
COURTLISTENER_TOKEN=

# Google Cloud project ID (for BigQuery patent queries, free tier: 1TB/month)
# Setup: https://cloud.google.com/bigquery/docs/quickstarts
GCP_PROJECT_ID=

# SEC EDGAR User-Agent (required, no key needed)
EDGAR_USER_AGENT=YourName your.email@example.com
